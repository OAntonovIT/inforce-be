generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   @db.VarChar(255)
  name      String
  role      Role     @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Book {
  id        String   @id @default(uuid())
  name      String   @unique
  author    String
  pageCount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("books")
}